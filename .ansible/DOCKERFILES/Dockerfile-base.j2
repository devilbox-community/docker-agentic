# vi: ft=dockerfile
{{ edit_comment_base }}
{% import './jinja2/macros-work.j2' as fn %}

FROM debian:{{ debian_version }} AS base

###
### Labels
###
# https://github.com/opencontainers/image-spec/blob/master/annotations.md
#LABEL "org.opencontainers.image.created"=""
#LABEL "org.opencontainers.image.version"=""
#LABEL "org.opencontainers.image.revision"=""
LABEL "maintainer"="Toan Nguyen <devilbox@nntoan.com>"
LABEL "org.opencontainers.image.authors"="Toan Nguyen <devilbox@nntoan.com>"
LABEL "org.opencontainers.image.url"="https://github.com/devilbox-community/docker-agentic"
LABEL "org.opencontainers.image.documentation"="https://github.com/devilbox-community/docker-agentic"
LABEL "org.opencontainers.image.source"="https://github.com/devilbox-community/docker-agentic"
LABEL "org.opencontainers.image.vendor"="Devilbox Community"
LABEL "org.opencontainers.image.licenses"="MIT"
LABEL "org.opencontainers.image.ref.name"="base"
LABEL "org.opencontainers.image.title"="Devilbox Agentic (base)"
LABEL "org.opencontainers.image.description"="Devilbox container shipping agentic coding CLIs (base stage)"

ARG MY_USER=devilbox
ARG MY_GROUP=devilbox
ARG MY_UID=1000
ARG MY_GID=1000

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

###
### Essential system packages (git, curl, ca-certificates, tini, sudo, locales)
###
RUN set -eux \
    && apt-get update \
    && apt-get install -y --no-install-recommends --no-install-suggests \
        bash \
        ca-certificates \
        curl \
        git \
        gnupg \
        locales \
        lsb-release \
        passwd \
        socat \
        sudo \
        tini \
        tzdata \
        wget \
    && echo "en_US.UTF-8 UTF-8" > /etc/locale.gen \
    && locale-gen \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

###
### gh CLI apt repository key (gh itself installed in work, not base)
###
RUN set -eux \
    && install -d -m 0755 /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list

###
### User and group creation
###
RUN set -eux \
    && if getent group "${MY_GID}" >/dev/null; then groupmod -n "${MY_GROUP}" "$(getent group "${MY_GID}" | cut -d: -f1)"; else groupadd -g "${MY_GID}" "${MY_GROUP}"; fi \
    && if getent passwd "${MY_UID}" >/dev/null; then usermod -l "${MY_USER}" -d "/home/${MY_USER}" -m "$(getent passwd "${MY_UID}" | cut -d: -f1)"; else useradd -m -u "${MY_UID}" -g "${MY_GID}" -s /bin/bash "${MY_USER}"; fi \
    && usermod -g "${MY_GROUP}" -s /bin/bash "${MY_USER}" \
    && echo "${MY_USER} ALL=(ALL) NOPASSWD: ALL" > "/etc/sudoers.d/${MY_USER}" \
    && chmod 0440 "/etc/sudoers.d/${MY_USER}" \
    && mkdir -p /shared/httpd /startup.1.d /startup.2.d \
    && chown -R "${MY_USER}:${MY_GROUP}" /shared /home/${MY_USER}

COPY data/docker-entrypoint.sh /docker-entrypoint.sh
COPY data/docker-entrypoint.d /docker-entrypoint.d
COPY data/startup.1.d/ /startup.1.d/
COPY data/startup.2.d/ /startup.2.d/
COPY data/motd /etc/motd

RUN set -eux \
    && chmod +x /docker-entrypoint.sh \
    && find /docker-entrypoint.d /startup.1.d /startup.2.d -type f -name '*.sh' -exec chmod +x {} + \
    && chown -R "${MY_USER}:${MY_GROUP}" /docker-entrypoint.d /startup.1.d /startup.2.d \
    && install -d -o "${MY_USER}" -g "${MY_GROUP}" /opt/agentic-tools \
    && install -d -m 1777 /var/lock

ENTRYPOINT ["/usr/bin/tini", "--", "/docker-entrypoint.sh"]
CMD ["bash"]
