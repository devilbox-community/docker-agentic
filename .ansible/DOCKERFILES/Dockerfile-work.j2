# vi: ft=dockerfile
{{ edit_comment_work }}
{% import './jinja2/macros-work.j2' as fn %}

FROM ubuntu:{{ ubuntu_version }} AS base

ARG MY_USER=devilbox
ARG MY_GROUP=devilbox
ARG MY_UID=1000
ARG MY_GID=1000
ARG GO_VERSION={{ go_version }}
ARG TARGETARCH

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PATH=/root/.local/bin:/home/devilbox/.cargo/bin:/home/devilbox/go/bin:/usr/local/go/bin:/home/devilbox/.local/bin:${PATH}

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN set -eux \
    && apt-get update \
    && apt-get install -y --no-install-recommends --no-install-suggests \
        bash \
        build-essential \
        ca-certificates \
        curl \
        git \
        gnupg \
        jq \
        openssh-client \
        passwd \
        python3 \
        python3-pip \
        pipx \
        sudo \
        tini \
        tzdata \
        xz-utils \
    && install -d -m 0755 /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_{{ node_major }}.x nodistro main" \
        > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends --no-install-suggests nodejs \
    && corepack enable \
    && rm -rf /var/lib/apt/lists/*

RUN set -eux \
    && case "${TARGETARCH:-amd64}" in \
        amd64) go_arch="amd64" ;; \
        arm64) go_arch="arm64" ;; \
        *) echo "Unsupported TARGETARCH: ${TARGETARCH}"; exit 1 ;; \
    esac \
    && curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${go_arch}.tar.gz" -o /tmp/go.tgz \
    && rm -rf /usr/local/go \
    && tar -C /usr/local -xzf /tmp/go.tgz \
    && rm -f /tmp/go.tgz

RUN set -eux \
    && if getent group "${MY_GID}" >/dev/null; then groupmod -n "${MY_GROUP}" "$(getent group "${MY_GID}" | cut -d: -f1)"; else groupadd -g "${MY_GID}" "${MY_GROUP}"; fi \
    && if getent passwd "${MY_UID}" >/dev/null; then usermod -l "${MY_USER}" -d "/home/${MY_USER}" -m "$(getent passwd "${MY_UID}" | cut -d: -f1)"; else useradd -m -u "${MY_UID}" -g "${MY_GID}" -s /bin/bash "${MY_USER}"; fi \
    && usermod -g "${MY_GROUP}" -s /bin/bash "${MY_USER}" \
    && echo "${MY_USER} ALL=(ALL) NOPASSWD: ALL" > "/etc/sudoers.d/${MY_USER}" \
    && chmod 0440 "/etc/sudoers.d/${MY_USER}" \
    && mkdir -p /shared/httpd /startup.1.d /startup.2.d \
    && chown -R "${MY_USER}:${MY_GROUP}" /shared /home/${MY_USER}

RUN set -eux \
    && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | su - "${MY_USER}" -c "sh -s -- -y --profile {{ rustup_profile }}" \
    && su - "${MY_USER}" -c "rustup --version && cargo --version"

COPY bin/docker-entrypoint.sh /docker-entrypoint.sh
COPY data/startup.1.d/ /startup.1.d/
COPY data/startup.2.d/ /startup.2.d/
COPY data/motd /etc/motd

RUN set -eux \
    && chmod +x /docker-entrypoint.sh \
    && find /startup.1.d /startup.2.d -type f -name '*.sh' -exec chmod +x {} + \
    && chown -R "${MY_USER}:${MY_GROUP}" /startup.1.d /startup.2.d

# Release builds tag the base stage as {{ docker_user }}/{{ image_name }}:base-{{ release }}.
FROM base AS work

USER root

{% set build_deps = [] -%}
{%- for tool in agentic_tools_enabled -%}
    {%- for dep in fn.get_build_dep(tool, agentic_tools_available) | from_json -%}
        {%- if dep -%}{{- build_deps.append(dep) -}}{%- endif -%}
    {%- endfor -%}
{%- endfor -%}
{%- if build_deps %}
RUN set -eux \
    && apt-get update \
    && apt-get install -y --no-install-recommends --no-install-suggests \
{% for build_dep in build_deps | unique | sort %}
        {{ build_dep }} \
{% endfor %}
    && rm -rf /var/lib/apt/lists/*
{%- endif %}

{% set apt_tools = [] -%}
{%- for tool in agentic_tools_enabled -%}
    {%- if fn.get_type(tool, agentic_tools_available) == 'apt' -%}
        {{- apt_tools.append(fn.tool_apt_get_package(tool, agentic_tools_available)) -}}
    {%- endif -%}
{%- endfor -%}
{%- if apt_tools %}
RUN set -eux \
    && apt-get update \
    && apt-get install -y --no-install-recommends --no-install-suggests \
{% for apt_tool in apt_tools | unique | sort %}
        {{ apt_tool }} \
{% endfor %}
    && rm -rf /var/lib/apt/lists/*
{%- endif %}

{% for tool in agentic_tools_enabled %}
{% if fn.get_type(tool, agentic_tools_available) in ['npm', 'pip', 'curl', 'custom'] %}
# -------------------- {{ tool }} --------------------
RUN set -eux; \
{% set pre = fn.get_pre(tool, agentic_tools_available) | trim %}
{% set post = fn.get_post(tool, agentic_tools_available) | trim %}
{% if pre in ['None', 'none', 'null', '~'] %}{% set pre = '' %}{% endif %}
{% if post in ['None', 'none', 'null', '~'] %}{% set post = '' %}{% endif %}
{% if pre | length %}
    {{ fn.get_pre(tool, agentic_tools_available) }}; \
{% endif %}
{% if fn.get_type(tool, agentic_tools_available) == 'npm' %}
    npm install -g {{ fn.tool_npm_get_package(tool, agentic_tools_available) }}{{ fn.tool_npm_get_version(tool, agentic_tools_available) }}; \
{% elif fn.get_type(tool, agentic_tools_available) == 'pip' %}
    pipx install {{ fn.tool_pip_get_package(tool, agentic_tools_available) }}{{ fn.tool_pip_get_version(tool, agentic_tools_available) }}; \
    ln -sf /root/.local/bin/{{ fn.get_binary(tool, agentic_tools_available) }} /usr/local/bin/{{ fn.get_binary(tool, agentic_tools_available) }}; \
    chmod -R a+rx /root; \
{% elif fn.get_type(tool, agentic_tools_available) == 'curl' %}
    {{ fn.tool_curl_get_command(tool, agentic_tools_available) }}; \
{% elif fn.get_type(tool, agentic_tools_available) == 'custom' %}
    {{ fn.tool_custom_get_command(tool, agentic_tools_available) }}; \
{% endif %}
{% if post | length %}
    {{ fn.get_post(tool, agentic_tools_available) }}; \
{% endif %}
    true
{% endif %}
{% endfor %}

USER devilbox
WORKDIR /shared/httpd

ENTRYPOINT ["/usr/bin/tini", "--", "/docker-entrypoint.sh"]
CMD ["bash"]
