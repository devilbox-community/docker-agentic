# vi: ft=dockerfile
{{ edit_comment_work }}
{% import './jinja2/macros-work.j2' as fn %}

########################################################################################################################
########################################################################################################################
###
### Stage 1/7: Devilbox Agentic work image (HELP BUILDER)
###
########################################################################################################################
########################################################################################################################

###
### Installs all cli tools required to install custom tools
###
FROM {{ docker_user }}/{{ image_name }}:base AS agentic-work-help-builder

{% set build_deps = [] -%}
{%- for tool in help_software_enabled -%}
    {%- for dep in fn.get_build_dep(tool, help_software_available) | from_json -%}
        {%- if dep -%}
            {{- build_deps.append(dep) -}}
        {%- endif -%}
    {%- endfor -%}
{%- endfor -%}
{%- if build_deps %}
###
### Install build_dep
###
RUN set -eux \
    && DEBIAN_FRONTEND=noninteractive apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends --no-install-suggests \
{% for build_dep in build_deps | unique | sort %}
        {{ build_dep }} \
{% endfor %}
    && rm -rf /var/lib/apt/lists/*
{%- endif %}

{% set run_deps = [] -%}
{%- for tool in help_software_enabled -%}
    {%- for dep in fn.get_run_dep(tool, help_software_available) | from_json -%}
        {%- if dep -%}
            {{- run_deps.append(dep) -}}
        {%- endif -%}
    {%- endfor -%}
{%- endfor -%}
{%- if run_deps %}
###
### Install run_dep
###
RUN set -eux \
    && DEBIAN_FRONTEND=noninteractive apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends --no-install-suggests \
{% for run_dep in run_deps | unique | sort %}
        {{ run_dep }} \
{% endfor %}
    && rm -rf /var/lib/apt/lists/*
{%- endif %}

ARG TARGETARCH

###
### Devilbox required helper tools from group_vars (work-help.yml)
###
{% for tool in help_software_enabled -%}
    {# Not disabled #}
    {%- if fn.is_not_disabled(tool, help_software_available) -%}
        {{- "\n" }}# -------------------- {{ tool }} --------------------
        {{- "\n" }}RUN set -eux \
        {#- -#}
        {#- [PRE] -#}
        {%- if fn.get_pre(tool, help_software_available) | length -%}
            {{ "\n\t" }}&& {{ fn.get_pre(tool, help_software_available) | indent( "\t" ) }}{{ "\t\\" }}
        {%- endif -%}
        {#- -#}
        {#- [COMMAND] -#}
        {%- if fn.get_type(tool, help_software_available) == 'custom' -%}
            {{ "\n\t" }}&& {{ fn.tool_custom_get_command(tool, help_software_available) | indent( "\t" ) }}{{ "\t\\" }}
        {%- endif -%}
        {#- -#}
        {#- [POST] -#}
        {%- if fn.get_post(tool, help_software_available) | length -%}
            {{ "\n\t" }}&& {{ fn.get_post(tool, help_software_available) | indent( "\t" ) }}{{ "\t\\" }}
        {%- endif -%}
        {#- -#}
        {#- Finalize -#}
        {{ "\n\t" }}&& true{{ "\n" }}
    {%- endif -%}
{%- endfor %}



########################################################################################################################
########################################################################################################################
###
### Stage 2/7: Devilbox Agentic work image (HELP)
###
########################################################################################################################
########################################################################################################################

###
### Copies all cli tools required to run Agentic into a clean image
###
FROM {{ docker_user }}/{{ image_name }}:base AS agentic-work-help

{% set run_deps = [] -%}
{%- for tool in help_software_enabled -%}
    {%- for dep in fn.get_run_dep(tool, help_software_available) | from_json -%}
        {%- if dep -%}
            {{- run_deps.append(dep) -}}
        {%- endif -%}
    {%- endfor -%}
{%- endfor -%}
{%- if run_deps %}
###
### Install run_dep
###
RUN set -eux \
    && DEBIAN_FRONTEND=noninteractive apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends --no-install-suggests \
{% for run_dep in run_deps | unique | sort %}
        {{ run_dep }} \
{% endfor %}
    && rm -rf /var/lib/apt/lists/*
{% endif %}

###
### Copy nvm
###
COPY --from=agentic-work-help-builder {{ nvm_home }} {{ nvm_home }}

###
### Copy Go
###
COPY --from=agentic-work-help-builder {{ go_home }} {{ go_home }}

###
### Copy binaries (/usr/local/bin)
###
COPY --from=agentic-work-help-builder /usr/local/bin /usr/local/bin

###
### Python packages
###
COPY --from=agentic-work-help-builder /usr/local/lib /usr/local/lib

###
### Set permission for home binaries
###
RUN set -eux \
    && chown -Rf ${MY_USER}:${MY_GROUP} {{ nvm_home }} \
    && chown -Rf ${MY_USER}:${MY_GROUP} /home/${MY_USER}/go

###
### Configure Bash (nvm, go, bun)
###
RUN set -eux \
    && { \
        echo; \
        echo "# [Devilbox] Ensure go, node, npm, npx, bun are in PATH"; \
        echo 'PATH="{{ go_home }}/bin:${PATH}"'; \
        echo 'PATH="{{ nvm_home }}/current/bin:${PATH}"'; \
        echo 'PATH="${HOME}/go/bin:${PATH}"'; \
        echo "export PATH"; \
        echo; \
        echo "# [Devilbox] Ensure to load nvm"; \
        echo 'export NVM_DIR="{{ nvm_home }}"'; \
        echo '[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm'; \
        echo '[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion'; \
    } | tee -a /home/${MY_USER}/.bashrc /root/.bashrc \
    && chown ${MY_USER}:${MY_GROUP} /home/${MY_USER}/.bashrc



########################################################################################################################
########################################################################################################################
###
### Stage 3/7: Devilbox Agentic work image (HELP TEST)
###
########################################################################################################################
########################################################################################################################

###
### Test all Devilbox cli utils if copying was successful
###
FROM agentic-work-help AS agentic-work-help-test

###
### Devilbox required helper tools from group_vars (work-help.yml)
###
{% for tool in help_software_enabled -%}
    {# Not disabled #}
    {%- if fn.is_not_disabled(tool, help_software_available) -%}
        {{- "\n" }}# -------------------- {{ tool }} --------------------
        {{- "\n" }}RUN set -eux \
        {#- -#}
        {#- [CHECK] -#}
        {%- if 'check' in help_software_available[tool] -%}
            {{ "\n\t" }}&& {{ help_software_available[tool]['check'] | indent( "\t" ) }}{{ "\t\\" }}
        {%- endif -%}
        {#- -#}
        {#- Finalize -#}
        {{ "\n\t" }}&& true{{ "\n" }}
    {%- endif -%}
{%- endfor %}



########################################################################################################################
########################################################################################################################
###
### Stage 4/7: Devilbox Agentic work image (TOOLS BUILDER)
###
########################################################################################################################
########################################################################################################################

###
### This stage can be easily modified by adding tools into the extra_tools/ directory.
###
FROM agentic-work-help AS agentic-work-tools-builder

{% set build_deps = [] -%}
{%- set run_deps = [] -%}
{%- set tools_apt = [] -%}
{%- for tool in extra_tools -%}
    {%- for dep in fn.get_build_dep(tool, extra_tools_available) | from_json -%}
        {%- if dep -%}
            {{- build_deps.append(dep) -}}
        {%- endif -%}
    {%- endfor -%}
    {%- for dep in fn.get_run_dep(tool, extra_tools_available) | from_json -%}
        {%- if dep -%}
            {{- run_deps.append(dep) -}}
        {%- endif -%}
    {%- endfor -%}
    {%- if fn.is_not_disabled(tool, extra_tools_available) -%}
        {%- if fn.tool_apt_get_package(tool, extra_tools_available) -%}
            {{- tools_apt.append(fn.tool_apt_get_package(tool, extra_tools_available)) -}}
        {%- endif -%}
    {%- endif -%}
{%- endfor %}

{%- if build_deps or run_deps or tools_apt -%}
###
### Install build_dep, run_dep or tools type: apt
###
RUN set -eux \
    && DEBIAN_FRONTEND=noninteractive apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends --no-install-suggests \
    {{- "\n" -}}
    {%- if build_deps -%}
        {{- "\t\t# ---------- build_deps ----------\n" -}}
        {%- for apt in build_deps | unique | sort -%}
                {{- "\t\t" + apt + " \\" + "\n" -}}
        {%- endfor -%}
    {%- endif -%}
    {%- if run_deps -%}
        {{- "\t\t# ---------- run_deps ----------\n" -}}
        {%- for apt in run_deps | unique | sort -%}
                {{- "\t\t" + apt + " \\" + "\n" -}}
        {%- endfor -%}
    {%- endif -%}
    {%- if tools_apt -%}
        {{- "\t\t# ---------- type: apt ----------\n" -}}
        {%- for apt in tools_apt | unique | sort -%}
                {{- "\t\t" + apt + " \\" + "\n" -}}
        {%- endfor -%}
    {%- endif -%}
    {{- "\t" -}}&& rm -rf /var/lib/apt/lists/*{{- "\n" -}}
{% endif %}

###
### Install defined extra_tools
###
{{ fn.install_tool_layers(extra_tools, extra_tools_available) }}

# ----- Default-enabled extra tools (symlinked to /usr/local/bin/ at build time): -----
{% for slug in extra_tools_enabled_by_default %}
# {{ slug }}  ({{ extra_tools_available[slug].all.binary }})
{% endfor %}
# ----- Installed-only extra tools (binary exists, no PATH symlink by default): -----
{% for slug in extra_tools_installed_only %}
# {{ slug }}  ({{ extra_tools_available[slug].all.binary }})
{% endfor %}



########################################################################################################################
########################################################################################################################
###
### Stage 5/7: Devilbox Agentic work image (TOOLS)
###
########################################################################################################################
########################################################################################################################

###
### This stage can be easily modified by adding tools into the extra_tools/ directory.
###
FROM agentic-work-help AS agentic-work-tools

{% set run_deps = [] -%}
{%- set tools_apt = [] -%}
{%- for tool in extra_tools -%}
    {%- for dep in fn.get_run_dep(tool, extra_tools_available) | from_json -%}
        {%- if dep -%}
            {{- run_deps.append(dep) -}}
        {%- endif -%}
    {%- endfor -%}
    {%- if fn.is_not_disabled(tool, extra_tools_available) -%}
        {%- if fn.tool_apt_get_package(tool, extra_tools_available) -%}
            {{- tools_apt.append(fn.tool_apt_get_package(tool, extra_tools_available)) -}}
        {%- endif -%}
    {%- endif -%}
{%- endfor %}

{%- if run_deps or tools_apt -%}
###
### Install run_dep or tools type: apt
###
RUN set -eux \
    && DEBIAN_FRONTEND=noninteractive apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends --no-install-suggests \
    {{- "\n" -}}
    {%- if run_deps -%}
        {{- "\t\t# ---------- run_deps ----------\n" -}}
        {%- for apt in run_deps | unique | sort -%}
                {{- "\t\t" + apt + " \\" + "\n" -}}
        {%- endfor -%}
    {%- endif -%}
    {%- if tools_apt -%}
        {{- "\t\t# ---------- type: apt ----------\n" -}}
        {%- for apt in tools_apt | unique | sort -%}
                {{- "\t\t" + apt + " \\" + "\n" -}}
        {%- endfor -%}
    {%- endif -%}
    {{- "\t" -}}&& rm -rf /var/lib/apt/lists/*{{- "\n" -}}
{% endif %}

###
### Copy extra tools from builder
###
COPY --from=agentic-work-tools-builder /opt/agentic-tools /opt/agentic-tools

###
### Copy Custom (binaries in /usr/local/bin)
###
COPY --from=agentic-work-tools-builder /usr/local/bin /usr/local/bin

###
### Set permission for agentic tools
###
RUN set -eux \
    && chown -Rf ${MY_USER}:${MY_GROUP} /opt/agentic-tools



########################################################################################################################
########################################################################################################################
###
### Stage 6/7: Devilbox Agentic work image (TOOLS TEST)
###
########################################################################################################################
########################################################################################################################

###
### Test all Devilbox cli utils if copying was successful
###
FROM agentic-work-tools AS agentic-work-tools-test

{% for tool in extra_tools -%}
    {%- if fn.is_not_disabled(tool, extra_tools_available) -%}
