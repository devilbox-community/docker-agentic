FROM ubuntu:24.04 AS base

ARG MY_USER=devilbox
ARG MY_GROUP=devilbox
ARG MY_UID=1000
ARG MY_GID=1000
ARG GO_VERSION=1.23.4
ARG TARGETARCH

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PATH=/root/.local/bin:/home/devilbox/.cargo/bin:/home/devilbox/go/bin:/usr/local/go/bin:/home/devilbox/.local/bin:${PATH}

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN set -eux \
    && apt-get update \
    && apt-get install -y --no-install-recommends --no-install-suggests \
        bash \
        build-essential \
        ca-certificates \
        curl \
        git \
        gnupg \
        jq \
        openssh-client \
        passwd \
        python3 \
        python3-pip \
        pipx \
        sudo \
        tini \
        tzdata \
        xz-utils \
    && install -d -m 0755 /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" \
        > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends --no-install-suggests nodejs \
    && corepack enable \
    && rm -rf /var/lib/apt/lists/*

RUN set -eux \
    && case "${TARGETARCH:-amd64}" in \
        amd64) go_arch="amd64" ;; \
        arm64) go_arch="arm64" ;; \
        *) echo "Unsupported TARGETARCH: ${TARGETARCH}"; exit 1 ;; \
    esac \
    && curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${go_arch}.tar.gz" -o /tmp/go.tgz \
    && rm -rf /usr/local/go \
    && tar -C /usr/local -xzf /tmp/go.tgz \
    && rm -f /tmp/go.tgz

RUN set -eux \
    && if getent group "${MY_GID}" >/dev/null; then groupmod -n "${MY_GROUP}" "$(getent group "${MY_GID}" | cut -d: -f1)"; else groupadd -g "${MY_GID}" "${MY_GROUP}"; fi \
    && if getent passwd "${MY_UID}" >/dev/null; then usermod -l "${MY_USER}" -d "/home/${MY_USER}" -m "$(getent passwd "${MY_UID}" | cut -d: -f1)"; else useradd -m -u "${MY_UID}" -g "${MY_GID}" -s /bin/bash "${MY_USER}"; fi \
    && usermod -g "${MY_GROUP}" -s /bin/bash "${MY_USER}" \
    && echo "${MY_USER} ALL=(ALL) NOPASSWD: ALL" > "/etc/sudoers.d/${MY_USER}" \
    && chmod 0440 "/etc/sudoers.d/${MY_USER}" \
    && mkdir -p /shared/httpd /startup.1.d /startup.2.d \
    && chown -R "${MY_USER}:${MY_GROUP}" /shared /home/${MY_USER}

RUN set -eux \
    && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | su - "${MY_USER}" -c "sh -s -- -y --profile minimal" \
    && su - "${MY_USER}" -c "rustup --version && cargo --version"

COPY bin/docker-entrypoint.sh /docker-entrypoint.sh
COPY data/startup.1.d/ /startup.1.d/
COPY data/startup.2.d/ /startup.2.d/
COPY data/motd /etc/motd

RUN set -eux \
    && chmod +x /docker-entrypoint.sh \
    && find /startup.1.d /startup.2.d -type f -name '*.sh' -exec chmod +x {} + \
    && chown -R "${MY_USER}:${MY_GROUP}" /startup.1.d /startup.2.d

# Release builds tag the base stage as devilboxcommunity/agentic:base-latest.
FROM base AS work

USER root



# -------------------- aider --------------------
RUN set -eux; \
    pipx install aider-chat; \
    ln -sf /root/.local/bin/aider /usr/local/bin/aider; \
    chmod -R a+rx /root; \
    true
# -------------------- claude-code --------------------
RUN set -eux; \
    npm install -g @anthropic-ai/claude-code; \
    true
# -------------------- cline --------------------
RUN set -eux; \
    curl --version >/dev/null && printf '%s\n' '#!/bin/sh' 'echo "Use Cline in VS Code; this container persists config at /home/devilbox/.config/cline"' > /usr/local/bin/cline && chmod +x /usr/local/bin/cline; \
    true
# -------------------- codewhale --------------------
RUN set -eux; \
    curl --version >/dev/null && printf '%s\n' '#!/usr/bin/env bash' 'echo "Tool codewhale is not yet publicly available; config dir persisted at /home/devilbox/.config/codewhale"' 'exit 0' > /usr/local/bin/codewhale && chmod +x /usr/local/bin/codewhale && mkdir -p /home/devilbox/.config/codewhale; \
    true
# -------------------- codex --------------------
RUN set -eux; \
    npm install -g @openai/codex; \
    true
# -------------------- continue --------------------
RUN set -eux; \
    npm install -g @continuedev/cli; \
    true
# -------------------- crush --------------------
RUN set -eux; \
    npm install -g @charmland/crush; \
    mkdir -p /home/devilbox/.config/crush; \
    true
# -------------------- cursor --------------------
RUN set -eux; \
    curl --version >/dev/null && printf '%s\n' '#!/bin/sh' 'echo "Use Cursor IDE on the host; this container persists config at /home/devilbox/.cursor"' > /usr/local/bin/cursor-agent && chmod +x /usr/local/bin/cursor-agent; \
    true
# -------------------- gh-copilot --------------------
RUN set -eux; \
    if ! command -v gh >/dev/null 2>&1; then curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | gpg --dearmor -o /usr/share/keyrings/githubcli-archive-keyring.gpg && chmod a+r /usr/share/keyrings/githubcli-archive-keyring.gpg && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list && apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends gh && rm -rf /var/lib/apt/lists/*; fi; \
    gh copilot --help >/dev/null; \
    true
# -------------------- goose --------------------
RUN set -eux; \
    curl -fsSL https://github.com/block/goose/releases/download/stable/download_cli.sh | CONFIGURE=false bash && mv /root/.local/bin/goose /usr/local/bin/goose; \
    true
# -------------------- hermes --------------------
RUN set -eux; \
    curl --version >/dev/null && printf '%s\n' '#!/usr/bin/env bash' 'echo "Tool hermes is not yet publicly available; config dir persisted at /home/devilbox/.config/hermes"' 'exit 0' > /usr/local/bin/hermes && chmod +x /usr/local/bin/hermes && mkdir -p /home/devilbox/.config/hermes; \
    true
# -------------------- llm --------------------
RUN set -eux; \
    pipx install llm; \
    ln -sf /root/.local/bin/llm /usr/local/bin/llm; \
    chmod -R a+rx /root; \
    mkdir -p /home/devilbox/.config/io.datasette.llm; \
    true
# -------------------- opencode --------------------
RUN set -eux; \
    npm install -g opencode-ai; \
    true
# -------------------- qwen-code --------------------
RUN set -eux; \
    npm install -g @qwen-code/qwen-code; \
    true
# -------------------- reasonix --------------------
RUN set -eux; \
    curl --version >/dev/null && printf '%s\n' '#!/usr/bin/env bash' 'echo "Tool reasonix is not yet publicly available; config dir persisted at /home/devilbox/.config/reasonix"' 'exit 0' > /usr/local/bin/reasonix && chmod +x /usr/local/bin/reasonix && mkdir -p /home/devilbox/.config/reasonix; \
    true

USER devilbox
WORKDIR /shared/httpd

ENTRYPOINT ["/usr/bin/tini", "--", "/docker-entrypoint.sh"]
CMD ["bash"]
