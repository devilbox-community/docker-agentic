###
### Stage 1/7: Devilbox Agentic work image (HELP BUILDER)
###
########################################################################################################################
########################################################################################################################

###
### Installs all cli tools required to install custom tools
###
FROM devilboxcommunity/agentic:base AS agentic-work-help-builder

###
### Install build_dep
###
RUN set -eux \
    && DEBIAN_FRONTEND=noninteractive apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends --no-install-suggests \
        libpython3-dev \
        python3-dev \
    && rm -rf /var/lib/apt/lists/*
###
### Install run_dep
###
RUN set -eux \
    && DEBIAN_FRONTEND=noninteractive apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends --no-install-suggests \
        python3-distutils \
    && rm -rf /var/lib/apt/lists/*
ARG TARGETARCH

###
### Devilbox required helper tools from group_vars (work-help.yml)
###

# -------------------- comfort-tools --------------------
RUN set -eux \
	&& apt-get update
	\
	&& apt-get install -y --no-install-recommends --no-install-suggests \
	  bash-completion \
	  bzip2 \
	  direnv \
	  dnsutils \
	  fd-find \
	  gh \
	  htop \
	  iputils-ping \
	  jq \
	  nano \
	  netcat-openbsd \
	  openssh-client \
	  pipx \
	  procps \
	  psmisc \
	  python3 \
	  python3-pip \
	  python3-venv \
	  ripgrep \
	  socat \
	  tmux \
	  tree \
	  unzip \
	  vim \
	  xz-utils \
	  yq \
	  zip \
	\
	&& rm -rf /var/lib/apt/lists/* \
	&& apt-get clean
	\
	&& true

# -------------------- build-toolchain --------------------
RUN set -eux \
	&& apt-get update
	\
	&& apt-get install -y --no-install-recommends --no-install-suggests \
	  build-essential \
	  cmake \
	  g++ \
	  gcc \
	  libffi-dev \
	  libssl-dev \
	  make \
	  pkg-config \
	  python3-dev \
	\
	&& rm -rf /var/lib/apt/lists/*
	\
	&& true

# -------------------- python-pip --------------------
RUN set -eux \
	&& rm -rf /usr/lib/python3.*/EXTERNALLY-MANAGED 2>/dev/null || true
	\
	&& curl -sS -L --fail https://bootstrap.pypa.io/get-pip.py | python3 \
	\
	&& curl -LsSf https://astral.sh/uv/install.sh | UV_INSTALL_DIR=/usr/local/bin sh \
	&& /bin/ls -1 /usr/local/lib/ | grep ^python | while read -r version; do \
	  cd "/usr/local/lib/${version}/" \
	  && find . -name '*.pyc' -print0 | xargs -0 -n1 rm -rf \
	  && find . -name '__pycache__' -print0 | xargs -0 -n1 rm -rf; \
	done \
	\
	&& true

# -------------------- go --------------------
RUN set -eux \
	&& GO_VERSION="1.23.4" \
	&& case "${TARGETARCH:-amd64}" in \
	  amd64) go_arch="amd64" ;; \
	  arm64) go_arch="arm64" ;; \
	  *) echo "Unsupported TARGETARCH: ${TARGETARCH}"; exit 1 ;; \
	esac \
	\
	&& curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${go_arch}.tar.gz" -o /tmp/go.tgz \
	&& rm -rf /usr/local/go \
	&& tar -C /usr/local -xzf /tmp/go.tgz \
	&& rm -f /tmp/go.tgz \
	\
	&& mkdir -p /home/devilbox/go/bin \
	&& chown -R devilbox:devilbox /home/devilbox/go \
	\
	&& true

# -------------------- nvm --------------------
RUN set -eux \
	&& NODE_VERSION="--lts" \
	&& NVM_VERSION="v0.40.4" \
	\
	&& mkdir -p /opt/nvm \
	&& curl -o- "https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_VERSION}/install.sh" \
	  | NVM_DIR="/opt/nvm" PROFILE=/dev/null bash \
	&& chown -Rf devilbox:devilbox "/opt/nvm" \
	\
	&& runuser -l devilbox -c ". /opt/nvm/nvm.sh; nvm install ${NODE_VERSION}" \
	&& runuser -l devilbox -c ". /opt/nvm/nvm.sh; nvm use ${NODE_VERSION}" \
	&& runuser -l devilbox -c ". /opt/nvm/nvm.sh; corepack enable" \
	\
	&& NODE_DIR="$(runuser -l devilbox -c '. /opt/nvm/nvm.sh; nvm which default | xargs dirname')" \
	&& ln -sfn "$(dirname ${NODE_DIR})" /opt/nvm/current \
	&& for bin in node npm npx corepack; do \
	  [ -f "${NODE_DIR}/${bin}" ] && ln -sf "${NODE_DIR}/${bin}" "/usr/local/bin/${bin}"; \
	done \
	\
	&& chmod 0777 /opt/nvm \
	&& find /opt/nvm -type f -print0 | xargs -n1 -0 chmod go+w || true \
	&& find /opt/nvm -type d -print0 | xargs -n1 -0 chmod 0777 || true \
	&& chown -Rf devilbox:devilbox /opt/nvm \
	\
	&& rm -rf /opt/nvm/.cache \
	&& NODE_CURRENT="$(runuser -l devilbox -c '. /opt/nvm/nvm.sh; node --version')" \
	&& rm -rf "/opt/nvm/versions/node/${NODE_CURRENT}/share" \
	&& rm -rf "/opt/nvm/versions/node/${NODE_CURRENT}/include" \
	\
	&& true

# -------------------- bun --------------------
RUN set -eux \
	&& BUN_VERSION="latest" \
	\
	&& curl -fsSL https://bun.sh/install | bash \
	&& install -m 0755 /root/.bun/bin/bun /usr/local/bin/bun \
	&& (install -m 0755 /root/.bun/bin/bunx /usr/local/bin/bunx 2>/dev/null || ln -sf /usr/local/bin/bun /usr/local/bin/bunx) \
	\
	&& rm -rf /root/.bun \
	\
	&& true



