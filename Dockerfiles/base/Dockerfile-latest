ARG MY_USER=devilbox
ARG MY_GROUP=devilbox
ARG MY_UID=1000
ARG MY_GID=1000
ARG GO_VERSION=1.23.4
ARG TARGETARCH

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PATH=/opt/nvm/current/bin:/home/devilbox/go/bin:/usr/local/go/bin:/home/devilbox/.local/bin:${PATH}

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN set -eux \
    && apt-get update \
    && apt-get install -y --no-install-recommends --no-install-suggests \
        ca-certificates \
        curl \
        gnupg \
        wget \
        lsb-release \
        sudo \
    && install -d -m 0755 /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends --no-install-suggests \
        bash \
        bash-completion \
        build-essential \
        bzip2 \
        cmake \
        direnv \
        dnsutils \
        fd-find \
        g++ \
        gcc \
        git \
        gh \
        htop \
        iputils-ping \
        jq \
        libffi-dev \
        libssl-dev \
        locales \
        make \
        nano \
        netcat-openbsd \
        openssh-client \
        passwd \
        pipx \
        pkg-config \
        procps \
        psmisc \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        ripgrep \
        socat \
        tini \
        tmux \
        tree \
        tzdata \
        unzip \
        vim \
        xz-utils \
        yq \
        zip \
    && echo "en_US.UTF-8 UTF-8" > /etc/locale.gen \
    && locale-gen \
    && curl -LsSf https://astral.sh/uv/install.sh | UV_INSTALL_DIR=/usr/local/bin sh \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

RUN set -eux \
    && case "${TARGETARCH:-amd64}" in \
        amd64) go_arch="amd64" ;; \
        arm64) go_arch="arm64" ;; \
        *) echo "Unsupported TARGETARCH: ${TARGETARCH}"; exit 1 ;; \
    esac \
    && curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${go_arch}.tar.gz" -o /tmp/go.tgz \
    && rm -rf /usr/local/go \
    && tar -C /usr/local -xzf /tmp/go.tgz \
    && rm -f /tmp/go.tgz

RUN set -eux \
    && if getent group "${MY_GID}" >/dev/null; then groupmod -n "${MY_GROUP}" "$(getent group "${MY_GID}" | cut -d: -f1)"; else groupadd -g "${MY_GID}" "${MY_GROUP}"; fi \
    && if getent passwd "${MY_UID}" >/dev/null; then usermod -l "${MY_USER}" -d "/home/${MY_USER}" -m "$(getent passwd "${MY_UID}" | cut -d: -f1)"; else useradd -m -u "${MY_UID}" -g "${MY_GID}" -s /bin/bash "${MY_USER}"; fi \
    && usermod -g "${MY_GROUP}" -s /bin/bash "${MY_USER}" \
    && echo "${MY_USER} ALL=(ALL) NOPASSWD: ALL" > "/etc/sudoers.d/${MY_USER}" \
    && chmod 0440 "/etc/sudoers.d/${MY_USER}" \
    && mkdir -p /shared/httpd /startup.1.d /startup.2.d \
    && chown -R "${MY_USER}:${MY_GROUP}" /shared /home/${MY_USER}

# Install nvm + Node LTS (replaces nodesource apt nodejs)
ENV NVM_DIR=/opt/nvm
ENV NVM_VERSION=v0.40.4
ENV NODE_VERSION=lts/*

RUN set -eux \
    && install -d -m 0755 /opt/nvm \
    && curl -fsSL "https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_VERSION}/install.sh" \
       | NVM_DIR=/opt/nvm PROFILE=/dev/null bash \
    && chown -R devilbox:devilbox /opt/nvm \
    && su -s /bin/bash -c '. /opt/nvm/nvm.sh && nvm install "'"${NODE_VERSION}"'" && nvm alias default "'"${NODE_VERSION}"'"' devilbox \
    && NODE_DIR="$(su -s /bin/bash -c '. /opt/nvm/nvm.sh && nvm which default | xargs dirname' devilbox)" \
    && ln -sfn "$(dirname ${NODE_DIR})" /opt/nvm/current \
    && for bin in node npm npx corepack; do \
         [ -f "${NODE_DIR}/${bin}" ] && ln -sf "${NODE_DIR}/${bin}" "/usr/local/bin/${bin}"; \
       done \
    && /usr/local/bin/corepack enable \
    && node --version && npm --version

RUN set -eux \
    && NODE_BIN="$(su -s /bin/bash -c '. /opt/nvm/nvm.sh && nvm which default | xargs dirname' devilbox)" \
    && echo "export PATH=\"${NODE_BIN}:\$PATH\"" > /etc/profile.d/nvm-path.sh \
    && echo "PATH=\"${NODE_BIN}:${PATH}\"" >> /etc/environment

# Install bun
ENV BUN_VERSION=latest
RUN set -eux \
    && curl -fsSL https://bun.sh/install | bash \
    && install -m 0755 /root/.bun/bin/bun /usr/local/bin/bun \
    && (install -m 0755 /root/.bun/bin/bunx /usr/local/bin/bunx 2>/dev/null || ln -sf /usr/local/bin/bun /usr/local/bin/bunx) \
    && rm -rf /root/.bun \
    && bun --version



# -------------------- claude-code --------------------
RUN set -eux; \
    mkdir -p /opt/agentic-tools/claude-code/bin; if curl -fsI https://claude.ai/install.sh >/dev/null 2>&1; then   curl -fsSL https://claude.ai/install.sh | bash;   for p in $(command -v claude 2>/dev/null) /root/.local/bin/claude /root/.claude/local/claude /usr/local/bin/claude; do     [ -x "$p" ] && install -D -m 0755 "$p" /opt/agentic-tools/claude-code/bin/claude && break;   done; else   echo 'WARN: claude-code primary probe failed; skipping (no npm fallback per user mandate)' >&2; fi; \
    mkdir -p /opt/agentic-tools/claude-code/bin; \
    if [ ! -x /opt/agentic-tools/claude-code/bin/claude ] && command -v claude >/dev/null 2>&1; then \
        install -m 0755 "$(command -v claude)" /opt/agentic-tools/claude-code/bin/claude; \
    fi; \
    true
# -------------------- codex --------------------
RUN set -eux; \
    mkdir -p /opt/agentic-tools/codex/bin; curl -fsSL https://chatgpt.com/codex/install.sh | CODEX_NON_INTERACTIVE=1 sh; install -D -m 0755 "${HOME}/.local/bin/codex" /opt/agentic-tools/codex/bin/codex; test -x /opt/agentic-tools/codex/bin/codex; \
    mkdir -p /opt/agentic-tools/codex/bin; \
    if [ ! -x /opt/agentic-tools/codex/bin/codex ] && command -v codex >/dev/null 2>&1; then \
        install -m 0755 "$(command -v codex)" /opt/agentic-tools/codex/bin/codex; \
    fi; \
    true
# -------------------- copilot --------------------
RUN set -eux; \
    mkdir -p /opt/agentic-tools/copilot/bin; PREFIX="${HOME}/.local" curl -fsSL https://gh.io/copilot-install | bash; install -D -m 0755 /usr/local/bin/copilot /opt/agentic-tools/copilot/bin/copilot; test -x /opt/agentic-tools/copilot/bin/copilot; \
    mkdir -p /opt/agentic-tools/copilot/bin; \
    if [ ! -x /opt/agentic-tools/copilot/bin/copilot ] && command -v copilot >/dev/null 2>&1; then \
        install -m 0755 "$(command -v copilot)" /opt/agentic-tools/copilot/bin/copilot; \
    fi; \
    true
# -------------------- opencode --------------------
RUN set -eux; \
    mkdir -p /opt/agentic-tools/opencode/bin && if curl -fsI https://opencode.ai/install >/dev/null 2>&1; then curl -fsSL https://opencode.ai/install | bash && for p in $(command -v opencode 2>/dev/null) /root/.opencode/bin/opencode /root/.local/bin/opencode /usr/local/bin/opencode; do [ -x "$p" ] && install -D -m 0755 "$p" /opt/agentic-tools/opencode/bin/opencode && break; done; else echo 'WARN: opencode primary probe failed; skipping (no npm fallback per user mandate)' >&2; fi; \
    mkdir -p /opt/agentic-tools/opencode/bin; \
    if [ ! -x /opt/agentic-tools/opencode/bin/opencode ] && command -v opencode >/dev/null 2>&1; then \
        install -m 0755 "$(command -v opencode)" /opt/agentic-tools/opencode/bin/opencode; \
    fi; \
    true
# -------------------- openspec --------------------
RUN set -eux; \
    npm install -g @fission-ai/openspec@latest; \
    mkdir -p /opt/agentic-tools/openspec/bin; \
    install -m 0755 "$(command -v openspec)" /opt/agentic-tools/openspec/bin/openspec; \
    mkdir -p /opt/agentic-tools/openspec/bin; \
    if [ ! -x /opt/agentic-tools/openspec/bin/openspec ] && command -v openspec >/dev/null 2>&1; then \
        install -m 0755 "$(command -v openspec)" /opt/agentic-tools/openspec/bin/openspec; \
    fi; \
    true
# -------------------- pi-coding-agent --------------------
RUN set -eux; \
    set -e; mkdir -p /opt/agentic-tools/pi-coding-agent/bin; if curl -fsI --max-time 10 https://pi.dev/install.sh >/dev/null 2>&1; then   curl -fsSL https://pi.dev/install.sh | sh || true;   for c in /usr/local/bin/pi /root/.local/bin/pi /usr/lib/node_modules/@earendil-works/pi-coding-agent/bin/pi /usr/local/lib/node_modules/@earendil-works/pi-coding-agent/bin/pi; do     if [ -x "$c" ] && [ ! -e /opt/agentic-tools/pi-coding-agent/bin/pi ]; then mv "$c" /opt/agentic-tools/pi-coding-agent/bin/pi; fi;   done; fi; if [ ! -x /opt/agentic-tools/pi-coding-agent/bin/pi ]; then   printf '%s\n' '#!/usr/bin/env bash' 'echo "WARNING: pi.dev install.sh unreachable at build time; stub installed."' 'exit 0' > /opt/agentic-tools/pi-coding-agent/bin/pi;   chmod +x /opt/agentic-tools/pi-coding-agent/bin/pi; fi; \
    mkdir -p /opt/agentic-tools/pi-coding-agent/bin; \
    if [ ! -x /opt/agentic-tools/pi-coding-agent/bin/pi ] && command -v pi >/dev/null 2>&1; then \
        install -m 0755 "$(command -v pi)" /opt/agentic-tools/pi-coding-agent/bin/pi; \
    fi; \
    true
# -------------------- reasonix --------------------
RUN set -eux; \
    npm install -g reasonix; \
    mkdir -p /opt/agentic-tools/reasonix/bin; \
    install -m 0755 "$(command -v reasonix)" /opt/agentic-tools/reasonix/bin/reasonix; \
    mkdir -p /opt/agentic-tools/reasonix/bin; \
    if [ ! -x /opt/agentic-tools/reasonix/bin/reasonix ] && command -v reasonix >/dev/null 2>&1; then \
        install -m 0755 "$(command -v reasonix)" /opt/agentic-tools/reasonix/bin/reasonix; \
    fi; \
    true


# ----- Default-enabled tools (symlinked to /usr/local/bin/ at build time): -----
# claude-code  (claude)
# codex  (codex)
# copilot  (copilot)
# opencode  (opencode)
# openspec  (openspec)
# pi-coding-agent  (pi)
# reasonix  (reasonix)
# ----- Installed-only tools (binary exists, no PATH symlink by default): -----

RUN set -eux \
    && ln -sfn /opt/agentic-tools/claude-code/bin/claude /usr/local/bin/claude \
    && ln -sfn /opt/agentic-tools/codex/bin/codex /usr/local/bin/codex \
    && ln -sfn /opt/agentic-tools/copilot/bin/copilot /usr/local/bin/copilot \
    && ln -sfn /opt/agentic-tools/opencode/bin/opencode /usr/local/bin/opencode \
    && ln -sfn /opt/agentic-tools/openspec/bin/openspec /usr/local/bin/openspec \
    && ln -sfn /opt/agentic-tools/pi-coding-agent/bin/pi /usr/local/bin/pi \
    && ln -sfn /opt/agentic-tools/reasonix/bin/reasonix /usr/local/bin/reasonix \
    && true

COPY data/docker-entrypoint.sh /docker-entrypoint.sh
COPY data/docker-entrypoint.d /docker-entrypoint.d
COPY data/startup.1.d/ /startup.1.d/
COPY data/startup.2.d/ /startup.2.d/
COPY data/motd /etc/motd

RUN set -eux \
    && chmod +x /docker-entrypoint.sh \
    && find /docker-entrypoint.d /startup.1.d /startup.2.d -type f -name '*.sh' -exec chmod +x {} + \
    && chown -R "${MY_USER}:${MY_GROUP}" /docker-entrypoint.d /startup.1.d /startup.2.d \
    && install -d -o "${MY_USER}" -g "${MY_GROUP}" /opt/agentic-tools \
    && install -d -m 1777 /var/lock

USER devilbox
WORKDIR /shared/httpd

ENTRYPOINT ["/usr/bin/tini", "--", "/docker-entrypoint.sh"]
CMD ["bash"]
