    set -e; mkdir -p /opt/agentic-tools/multica/bin; \ MULTICA_SRC="${MULTICA_SRC:-/workspace/multica}"; \ if [ -d "$MULTICA_SRC/apps/cli" ]; then \   cd "$MULTICA_SRC/apps/cli" && go build -o /opt/agentic-tools/multica/bin/multica ./cmd/multica; \ else \   echo "WARNING: multica sibling repo not bind-mounted at $MULTICA_SRC; skipping CLI build (Wave 8F1 compose stack still optional)"; \   printf '%s\n' '#!/usr/bin/env bash' 'echo "WARNING: multica CLI not built — sibling repo was absent at image build time."' 'exit 0' > /opt/agentic-tools/multica/bin/multica; \   chmod +x /opt/agentic-tools/multica/bin/multica; \ fi; \
    mkdir -p /opt/agentic-tools/multica/bin; \
    if [ ! -x /opt/agentic-tools/multica/bin/multica ] && command -v multica >/dev/null 2>&1; then \
        install -m 0755 "$(command -v multica)" /opt/agentic-tools/multica/bin/multica; \
    fi; \
    true
# -------------------- openclaude --------------------
RUN set -eux; \
    mkdir -p /opt/agentic-tools/openclaude/bin; npm install -g --prefix /opt/agentic-tools/openclaude @gitlawb/openclaude@0.16.1; test -x /opt/agentic-tools/openclaude/bin/openclaude; chmod +x /opt/agentic-tools/openclaude/bin/openclaude; \
    mkdir -p /opt/agentic-tools/openclaude/bin; \
    if [ ! -x /opt/agentic-tools/openclaude/bin/openclaude ] && command -v openclaude >/dev/null 2>&1; then \
        install -m 0755 "$(command -v openclaude)" /opt/agentic-tools/openclaude/bin/openclaude; \
    fi; \
    true
# -------------------- openclaw --------------------
RUN set -eux; \
    set -e; mkdir -p /opt/agentic-tools/openclaw/bin; \ if curl -fsI --max-time 10 https://openclaw.ai/install.sh >/dev/null 2>&1; then \   curl -fsSL https://openclaw.ai/install.sh | bash || true; \   for c in /root/.local/bin/openclaw /usr/local/bin/openclaw /root/.openclaw/bin/openclaw; do \     if [ -x "$c" ] && [ ! -e /opt/agentic-tools/openclaw/bin/openclaw ]; then mv "$c" /opt/agentic-tools/openclaw/bin/openclaw; fi; \   done; \ fi; \ if [ ! -x /opt/agentic-tools/openclaw/bin/openclaw ]; then \   printf '%s\n' '#!/usr/bin/env bash' 'echo "WARNING: openclaw install.sh unreachable at build time; stub installed."' 'exit 0' > /opt/agentic-tools/openclaw/bin/openclaw; \   chmod +x /opt/agentic-tools/openclaw/bin/openclaw; \ fi; \
    mkdir -p /opt/agentic-tools/openclaw/bin; \
    if [ ! -x /opt/agentic-tools/openclaw/bin/openclaw ] && command -v openclaw >/dev/null 2>&1; then \
        install -m 0755 "$(command -v openclaw)" /opt/agentic-tools/openclaw/bin/openclaw; \
    fi; \
    true
# -------------------- opencode --------------------
RUN set -eux; \
    mkdir -p /opt/agentic-tools/opencode/bin && if curl -fsI https://opencode.ai/install >/dev/null 2>&1; then curl -fsSL https://opencode.ai/install | bash && for p in $(command -v opencode 2>/dev/null) /root/.opencode/bin/opencode /root/.local/bin/opencode /usr/local/bin/opencode; do [ -x "$p" ] && install -D -m 0755 "$p" /opt/agentic-tools/opencode/bin/opencode && break; done; else echo 'WARN: opencode primary probe failed; skipping (no npm fallback per user mandate)' >&2; fi; \
    mkdir -p /opt/agentic-tools/opencode/bin; \
    if [ ! -x /opt/agentic-tools/opencode/bin/opencode ] && command -v opencode >/dev/null 2>&1; then \
        install -m 0755 "$(command -v opencode)" /opt/agentic-tools/opencode/bin/opencode; \
    fi; \
    true
