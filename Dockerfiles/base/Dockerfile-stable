# -------------------- pi-coding-agent --------------------
RUN set -eux; \
    set -e; mkdir -p /opt/agentic-tools/pi-coding-agent/bin; \ if curl -fsI --max-time 10 https://pi.dev/install.sh >/dev/null 2>&1; then \   curl -fsSL https://pi.dev/install.sh | sh || true; \   for c in /usr/local/bin/pi /root/.local/bin/pi /usr/lib/node_modules/@earendil-works/pi-coding-agent/bin/pi /usr/local/lib/node_modules/@earendil-works/pi-coding-agent/bin/pi; do \     if [ -x "$c" ] && [ ! -e /opt/agentic-tools/pi-coding-agent/bin/pi ]; then mv "$c" /opt/agentic-tools/pi-coding-agent/bin/pi; fi; \   done; \ fi; \ if [ ! -x /opt/agentic-tools/pi-coding-agent/bin/pi ]; then \   printf '%s\n' '#!/usr/bin/env bash' 'echo "WARNING: pi.dev install.sh unreachable at build time; stub installed."' 'exit 0' > /opt/agentic-tools/pi-coding-agent/bin/pi; \   chmod +x /opt/agentic-tools/pi-coding-agent/bin/pi; \ fi; \
    mkdir -p /opt/agentic-tools/pi-coding-agent/bin; \
    if [ ! -x /opt/agentic-tools/pi-coding-agent/bin/pi ] && command -v pi >/dev/null 2>&1; then \
        install -m 0755 "$(command -v pi)" /opt/agentic-tools/pi-coding-agent/bin/pi; \
    fi; \
    true
# -------------------- qoder --------------------
RUN set -eux; \
    mkdir -p /opt/agentic-tools/qoder/bin; version="1.0.11"; arch="$(uname -m)"; case "$arch" in x86_64) file="qodercli-linux-x64.tar.gz" ;; aarch64) file="qodercli-linux-arm64.tar.gz" ;; *) echo "Unsupported architecture: $arch" >&2; exit 1 ;; esac; tmpdir="$(mktemp -d)"; trap 'rm -rf "$tmpdir"' EXIT; curl -fsSL --retry 3 "https://qoder-ide.oss-accelerate.aliyuncs.com/qodercli/releases/${version}/${file}" -o "$tmpdir/$file"; tar -xzf "$tmpdir/$file" -C "$tmpdir"; find "$tmpdir" -type f -name qodercli -perm -111 -exec install -D -m 0755 {} /opt/agentic-tools/qoder/bin/qodercli \; -quit; test -x /opt/agentic-tools/qoder/bin/qodercli; \
    mkdir -p /opt/agentic-tools/qoder/bin; \
    if [ ! -x /opt/agentic-tools/qoder/bin/qodercli ] && command -v qodercli >/dev/null 2>&1; then \
        install -m 0755 "$(command -v qodercli)" /opt/agentic-tools/qoder/bin/qodercli; \
    fi; \
    true
# -------------------- qwen-code --------------------
RUN set -eux; \
    mkdir -p /opt/agentic-tools/qwen-code/bin /tmp/qwen-x && if curl -fsI https://github.com/QwenLM/qwen-code/releases/latest/download/qwen-code-linux-x64.tar.gz >/dev/null 2>&1; then curl -fsSL https://github.com/QwenLM/qwen-code/releases/latest/download/qwen-code-linux-x64.tar.gz | tar xz -C /tmp/qwen-x && BIN=$(find /tmp/qwen-x -type f -name 'qwen-code' | head -n1) && [ -n "$BIN" ] && install -D -m 0755 "$BIN" /opt/agentic-tools/qwen-code/bin/qwen-code && rm -rf /tmp/qwen-x; else echo 'WARN: qwen-code primary probe failed; skipping (no npm fallback per user mandate)' >&2; fi; \
    mkdir -p /opt/agentic-tools/qwen-code/bin; \
    if [ ! -x /opt/agentic-tools/qwen-code/bin/qwen-code ] && command -v qwen-code >/dev/null 2>&1; then \
        install -m 0755 "$(command -v qwen-code)" /opt/agentic-tools/qwen-code/bin/qwen-code; \
    fi; \
    true
# -------------------- reasonix --------------------
RUN set -eux; \
    mkdir -p /opt/agentic-tools/reasonix/bin /opt/agentic-tools/reasonix/lib; if curl -fsI https://github.com/esengine/DeepSeek-Reasonix >/dev/null 2>&1; then git clone --depth 1 https://github.com/esengine/DeepSeek-Reasonix /opt/agentic-tools/reasonix/src && python3 -m pip install --break-system-packages --target /opt/agentic-tools/reasonix/lib /opt/agentic-tools/reasonix/src; printf '%s\n' '#!/usr/bin/env bash' 'PYTHONPATH=/opt/agentic-tools/reasonix/lib exec python3 -m reasonix "$@"' > /opt/agentic-tools/reasonix/bin/reasonix && chmod +x /opt/agentic-tools/reasonix/bin/reasonix; else echo "WARNING reasonix upstream unavailable"; printf '%s\n' '#!/bin/sh' 'echo reasonix upstream unavailable at build time' 'exit 0' > /opt/agentic-tools/reasonix/bin/reasonix && chmod +x /opt/agentic-tools/reasonix/bin/reasonix; fi; \
    mkdir -p /opt/agentic-tools/reasonix/bin; \
    if [ ! -x /opt/agentic-tools/reasonix/bin/reasonix ] && command -v reasonix >/dev/null 2>&1; then \
        install -m 0755 "$(command -v reasonix)" /opt/agentic-tools/reasonix/bin/reasonix; \
    fi; \
    true
# -------------------- speckit --------------------
RUN set -eux; \
    mkdir -p /opt/agentic-tools/speckit/bin; python3 -m venv /opt/agentic-tools/speckit/venv; /opt/agentic-tools/speckit/venv/bin/python -m pip install --upgrade pip setuptools wheel; /opt/agentic-tools/speckit/venv/bin/python -m pip install git+https://github.com/github/spec-kit.git@v0.9.0; ln -sfn ../venv/bin/specify /opt/agentic-tools/speckit/bin/specify; test -x /opt/agentic-tools/speckit/bin/specify; \
    mkdir -p /opt/agentic-tools/speckit/bin; \
    if [ ! -x /opt/agentic-tools/speckit/bin/specify ] && command -v specify >/dev/null 2>&1; then \
        install -m 0755 "$(command -v specify)" /opt/agentic-tools/speckit/bin/specify; \
    fi; \
    true
# -------------------- vibe --------------------
RUN set -eux; \
    mkdir -p /opt/agentic-tools/vibe/bin; if ! command -v uv >/dev/null 2>&1; then curl -LsSf https://astral.sh/uv/install.sh | sh; export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"; fi; uv tool install mistral-vibe==2.13.0 --force; uv_bin_dir="$(uv tool dir --bin)"; ln -sfn "$uv_bin_dir/vibe" /opt/agentic-tools/vibe/bin/vibe; ln -sfn "$uv_bin_dir/vibe-acp" /opt/agentic-tools/vibe/bin/vibe-acp; test -x /opt/agentic-tools/vibe/bin/vibe; \
    mkdir -p /opt/agentic-tools/vibe/bin; \
    if [ ! -x /opt/agentic-tools/vibe/bin/vibe ] && command -v vibe >/dev/null 2>&1; then \
        install -m 0755 "$(command -v vibe)" /opt/agentic-tools/vibe/bin/vibe; \
    fi; \
    true


