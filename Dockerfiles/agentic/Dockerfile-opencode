###
### Installs the specified agent tool in a builder image to keep the final image clean.
###
FROM devilboxcommunity/agentic:work AS agentic-builder

USER root


###
### Install agent tool: opencode
###
# -------------------- opencode --------------------
RUN set -eux; \
	mkdir -p /opt/agentic-tools/opencode/bin && if curl -fsI https://opencode.ai/install >/dev/null 2>&1; then curl -fsSL https://opencode.ai/install | bash && for p in $(command -v opencode 2>/dev/null) /root/.opencode/bin/opencode /root/.local/bin/opencode /usr/local/bin/opencode; do [ -x "$p" ] && install -D -m 0755 "$p" /opt/agentic-tools/opencode/bin/opencode && break; done; else echo 'WARN: opencode primary probe failed; skipping (no npm fallback per user mandate)' >&2; fi; \
	mkdir -p /opt/agentic-tools/opencode/bin; \
	if [ ! -x /opt/agentic-tools/opencode/bin/opencode ] && command -v opencode >/dev/null 2>&1; then \
		install -m 0755 "$(command -v opencode)" /opt/agentic-tools/opencode/bin/opencode; \
	fi; \
	true



########################################################################################################################
########################################################################################################################
###
### Stage 2/4: Devilbox Agentic image (FINAL)
###
########################################################################################################################
########################################################################################################################

###
### Copies the installed agent tool binaries into a clean final image.
###
FROM devilboxcommunity/agentic:work AS opencode

USER root


###
### Copy agent tool binaries from builder
###
COPY --from=agentic-builder /opt/agentic-tools/opencode /opt/agentic-tools/opencode

###
### Default-enabled symlink
###
RUN set -eux \
    && ln -sfn /opt/agentic-tools/opencode/bin/opencode /usr/local/bin/opencode \
    && true


