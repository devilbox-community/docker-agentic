###
### Installs the specified agent tool in a builder image to keep the final image clean.
###
FROM devilboxcommunity/agentic:work AS agentic-builder

USER root


###
### Install agent tool: codex
###
# -------------------- codex --------------------
RUN set -eux; \
	mkdir -p /opt/agentic-tools/codex/bin; curl -fsSL https://chatgpt.com/codex/install.sh | CODEX_NON_INTERACTIVE=1 sh; install -D -m 0755 "${HOME}/.local/bin/codex" /opt/agentic-tools/codex/bin/codex; test -x /opt/agentic-tools/codex/bin/codex; \
	mkdir -p /opt/agentic-tools/codex/bin; \
	if [ ! -x /opt/agentic-tools/codex/bin/codex ] && command -v codex >/dev/null 2>&1; then \
		install -m 0755 "$(command -v codex)" /opt/agentic-tools/codex/bin/codex; \
	fi; \
	true



########################################################################################################################
########################################################################################################################
###
### Stage 2/4: Devilbox Agentic image (FINAL)
###
########################################################################################################################
########################################################################################################################

###
### Copies the installed agent tool binaries into a clean final image.
###
FROM devilboxcommunity/agentic:work AS codex

USER root


###
### Copy agent tool binaries from builder
###
COPY --from=agentic-builder /opt/agentic-tools/codex /opt/agentic-tools/codex

###
### Default-enabled symlink
###
RUN set -eux \
    && ln -sfn /opt/agentic-tools/codex/bin/codex /usr/local/bin/codex \
    && true


