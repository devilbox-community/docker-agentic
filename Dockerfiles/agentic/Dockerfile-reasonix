###
### Installs the specified agent tool in a builder image to keep the final image clean.
###
FROM devilboxcommunity/agentic:work AS agentic-builder

USER root


###
### Install agent tool: reasonix
###
# -------------------- reasonix --------------------
RUN set -eux; \
	npm install -g reasonix; \
	npm cache clean --force; \
	mkdir -p /opt/agentic-tools/reasonix/bin; \
	install -m 0755 "$(command -v reasonix)" /opt/agentic-tools/reasonix/bin/reasonix; \
	mkdir -p /opt/agentic-tools/reasonix/bin; \
	if [ ! -x /opt/agentic-tools/reasonix/bin/reasonix ] && command -v reasonix >/dev/null 2>&1; then \
		install -m 0755 "$(command -v reasonix)" /opt/agentic-tools/reasonix/bin/reasonix; \
	fi; \
	true



########################################################################################################################
########################################################################################################################
###
### Stage 2/4: Devilbox Agentic image (FINAL)
###
########################################################################################################################
########################################################################################################################

###
### Copies the installed agent tool binaries into a clean final image.
###
FROM devilboxcommunity/agentic:work AS reasonix

USER root


###
### Copy agent tool binaries from builder
###
COPY --from=agentic-builder /opt/agentic-tools/reasonix /opt/agentic-tools/reasonix

###
### Default-enabled symlink
###
RUN set -eux \
    && ln -sfn /opt/agentic-tools/reasonix/bin/reasonix /usr/local/bin/reasonix \
    && true


########################################################################################################################
########################################################################################################################
###
### Stage 3/4: Devilbox Agentic image (TEST)
