###
### Installs the specified agent tool in a builder image to keep the final image clean.
###
FROM devilboxcommunity/agentic:work AS agentic-builder

USER root


###
### Install agent tool: copilot
###
# -------------------- copilot --------------------
RUN set -eux; \
	mkdir -p /opt/agentic-tools/copilot/bin; PREFIX="${HOME}/.local" curl -fsSL https://gh.io/copilot-install | bash; install -D -m 0755 /usr/local/bin/copilot /opt/agentic-tools/copilot/bin/copilot; test -x /opt/agentic-tools/copilot/bin/copilot; \
	mkdir -p /opt/agentic-tools/copilot/bin; \
	if [ ! -x /opt/agentic-tools/copilot/bin/copilot ] && command -v copilot >/dev/null 2>&1; then \
		install -m 0755 "$(command -v copilot)" /opt/agentic-tools/copilot/bin/copilot; \
	fi; \
	true



########################################################################################################################
########################################################################################################################
###
### Stage 2/4: Devilbox Agentic image (FINAL)
###
########################################################################################################################
########################################################################################################################

###
### Copies the installed agent tool binaries into a clean final image.
###
FROM devilboxcommunity/agentic:work AS copilot

USER root


###
### Copy agent tool binaries from builder
###
COPY --from=agentic-builder /opt/agentic-tools/copilot /opt/agentic-tools/copilot

###
### Default-enabled symlink
###
RUN set -eux \
    && ln -sfn /opt/agentic-tools/copilot/bin/copilot /usr/local/bin/copilot \
    && true


########################################################################################################################
########################################################################################################################
###
### Stage 3/4: Devilbox Agentic image (TEST)
###
########################################################################################################################
########################################################################################################################

###
### Test the installed agent tool binary.
###
FROM copilot AS agentic-test

USER root

# -------------------- copilot --------------------
RUN set -eux \
    && copilot --version 2>&1 | grep -qE '[0-9]+\.[0-9]+' \
    && true

