###
### Installs the specified agent tool in a builder image to keep the final image clean.
###
FROM devilboxcommunity/agentic:work AS agentic-builder

USER root


###
### Install agent tool: qwen-code
###
# -------------------- qwen-code --------------------
RUN set -eux; \
	npm install -g @qwen-code/qwen-code@latest; \
	npm cache clean --force; \
	mkdir -p /opt/agentic-tools/qwen-code/bin; \
	install -m 0755 "$(command -v qwen)" /opt/agentic-tools/qwen-code/bin/qwen; \
	mkdir -p /opt/agentic-tools/qwen-code/bin; \
	if [ ! -x /opt/agentic-tools/qwen-code/bin/qwen ] && command -v qwen >/dev/null 2>&1; then \
		install -m 0755 "$(command -v qwen)" /opt/agentic-tools/qwen-code/bin/qwen; \
	fi; \
	true



########################################################################################################################
########################################################################################################################
###
### Stage 2/4: Devilbox Agentic image (FINAL)
###
########################################################################################################################
########################################################################################################################

###
### Copies the installed agent tool binaries into a clean final image.
###
FROM devilboxcommunity/agentic:work AS qwen-code

USER root


###
### Copy agent tool binaries from builder
###
COPY --from=agentic-builder /opt/agentic-tools/qwen-code /opt/agentic-tools/qwen-code

###
### Default-enabled symlink
###
RUN set -eux \
    && ln -sfn /opt/agentic-tools/qwen-code/bin/qwen /usr/local/bin/qwen \
    && true


