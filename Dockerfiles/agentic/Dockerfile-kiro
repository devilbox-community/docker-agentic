###
### Stage 1/4: Devilbox Agentic image (BUILDER)
###
########################################################################################################################
########################################################################################################################

###
### Installs the specified agent tool in a builder image to keep the final image clean.
###
FROM devilboxcommunity/agentic:work AS agentic-builder

USER root

###
### Install build_dep for kiro
###
RUN set -eux \
    && apt-get update \
    && apt-get install -y --no-install-recommends --no-install-suggests \
        libayatana-appindicator3-1 \
        libgtk-3-0 \
        libwebkit2gtk-4.1-0 \
    && rm -rf /var/lib/apt/lists/*
###
### Install agent tool: kiro
###
# -------------------- kiro --------------------
RUN set -eux; \
	mkdir -p /opt/agentic-tools/kiro/bin; wget https://desktop-release.q.us-east-1.amazonaws.com/latest/kiro-cli.deb -O /tmp/kiro-cli.deb; dpkg -i /tmp/kiro-cli.deb; apt-get install -f -y; install -D -m 0755 "$(which kiro-cli)" /opt/agentic-tools/kiro/bin/kiro-cli; test -x /opt/agentic-tools/kiro/bin/kiro-cli; \
	mkdir -p /opt/agentic-tools/kiro/bin; \
	if [ ! -x /opt/agentic-tools/kiro/bin/kiro-cli ] && command -v kiro-cli >/dev/null 2>&1; then \
		install -m 0755 "$(command -v kiro-cli)" /opt/agentic-tools/kiro/bin/kiro-cli; \
	fi; \
	true



########################################################################################################################
########################################################################################################################
###
### Stage 2/4: Devilbox Agentic image (FINAL)
###
########################################################################################################################
########################################################################################################################

###
### Copies the installed agent tool binaries into a clean final image.
###
FROM devilboxcommunity/agentic:work AS kiro

USER root

###
### Install run_dep for kiro
###
RUN set -eux \
    && apt-get update \
    && apt-get install -y --no-install-recommends --no-install-suggests \
        libayatana-appindicator3-1 \
        libgtk-3-0 \
        libwebkit2gtk-4.1-0 \
    && rm -rf /var/lib/apt/lists/*
###
### Copy agent tool binaries from builder
###
COPY --from=agentic-builder /opt/agentic-tools/kiro /opt/agentic-tools/kiro

###
### Default-enabled symlink
###
RUN set -eux \
    && ln -sfn /opt/agentic-tools/kiro/bin/kiro-cli /usr/local/bin/kiro-cli \
    && true


########################################################################################################################
########################################################################################################################
###
### Stage 3/4: Devilbox Agentic image (TEST)
###
########################################################################################################################
########################################################################################################################

###
### Test the installed agent tool binary.
###
FROM kiro AS agentic-test

USER root

# -------------------- kiro --------------------
RUN set -eux \
    && kiro-cli --version 2>&1 | grep -qiE '(kiro|[0-9]+\.[0-9]+)' \
    && true

