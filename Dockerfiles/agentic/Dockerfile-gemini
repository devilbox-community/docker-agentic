###
### Stage 1/4: Devilbox Agentic image (BUILDER)
###
########################################################################################################################
########################################################################################################################

###
### Installs the specified agent tool in a builder image to keep the final image clean.
###
FROM devilboxcommunity/agentic:work AS agentic-builder

USER root


###
### Install agent tool: gemini
###
# -------------------- gemini --------------------
RUN set -eux; \
	npm install -g @google/gemini-cli; \
	npm cache clean --force; \
	mkdir -p /opt/agentic-tools/gemini/bin; \
	install -m 0755 "$(command -v gemini)" /opt/agentic-tools/gemini/bin/gemini; \
	mkdir -p /opt/agentic-tools/gemini/bin; \
	if [ ! -x /opt/agentic-tools/gemini/bin/gemini ] && command -v gemini >/dev/null 2>&1; then \
		install -m 0755 "$(command -v gemini)" /opt/agentic-tools/gemini/bin/gemini; \
	fi; \
	true



########################################################################################################################
########################################################################################################################
###
### Stage 2/4: Devilbox Agentic image (FINAL)
###
########################################################################################################################
########################################################################################################################

###
### Copies the installed agent tool binaries into a clean final image.
###
FROM devilboxcommunity/agentic:work AS gemini

USER root


###
### Copy agent tool binaries from builder
###
COPY --from=agentic-builder /opt/agentic-tools/gemini /opt/agentic-tools/gemini

###
### Default-enabled symlink
###
RUN set -eux \
    && ln -sfn /opt/agentic-tools/gemini/bin/gemini /usr/local/bin/gemini \
    && true


########################################################################################################################
########################################################################################################################
###
### Stage 3/4: Devilbox Agentic image (TEST)
###
########################################################################################################################
########################################################################################################################

###
### Test the installed agent tool binary.
###
FROM gemini AS agentic-test

USER root

# -------------------- gemini --------------------
RUN set -eux \
    && gemini --version 2>&1 | grep -qiE '(gemini|not yet|[0-9]+\.[0-9]+)' \
    && true

