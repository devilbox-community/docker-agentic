###
### Stage 1/4: Devilbox Agentic image (BUILDER)
###
########################################################################################################################
########################################################################################################################

###
### Installs the specified agent tool in a builder image to keep the final image clean.
###
FROM devilboxcommunity/agentic:work AS agentic-builder

USER root


###
### Install agent tool: kilo-code
###
# -------------------- kilo-code --------------------
RUN set -eux; \
	npm install -g @kilocode/cli; \
	npm cache clean --force; \
	mkdir -p /opt/agentic-tools/kilo-code/bin; \
	install -m 0755 "$(command -v kilo)" /opt/agentic-tools/kilo-code/bin/kilo; \
	mkdir -p /opt/agentic-tools/kilo-code/bin; \
	if [ ! -x /opt/agentic-tools/kilo-code/bin/kilo ] && command -v kilo >/dev/null 2>&1; then \
		install -m 0755 "$(command -v kilo)" /opt/agentic-tools/kilo-code/bin/kilo; \
	fi; \
	true



########################################################################################################################
########################################################################################################################
###
### Stage 2/4: Devilbox Agentic image (FINAL)
###
########################################################################################################################
########################################################################################################################

###
### Copies the installed agent tool binaries into a clean final image.
###
FROM devilboxcommunity/agentic:work AS kilo-code

USER root


###
### Copy agent tool binaries from builder
###
COPY --from=agentic-builder /opt/agentic-tools/kilo-code /opt/agentic-tools/kilo-code

###
### Default-enabled symlink
###
RUN set -eux \
    && ln -sfn /opt/agentic-tools/kilo-code/bin/kilo /usr/local/bin/kilo \
    && true


########################################################################################################################
########################################################################################################################
###
### Stage 3/4: Devilbox Agentic image (TEST)
###
########################################################################################################################
########################################################################################################################

###
### Test the installed agent tool binary.
###
FROM kilo-code AS agentic-test

USER root

# -------------------- kilo-code --------------------
RUN set -eux \
    && kilo --version 2>&1 | grep -qE '[0-9]+\.[0-9]+' \
    && true

